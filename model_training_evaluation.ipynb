    "#Save and upload all three splits\n",
    "def save_to_s3(X, y, bucket, key):\n",
    "    df = pd.concat([y.reset_index(drop=True), X.reset_index(drop=True)], axis=1)\n",
    "    df.to_csv(f's3://{bucket}/{key}', header=False, index=False)\n",
