   "cell_type": "markdown",
   "id": "18581ddd",
   "metadata": {},
   "source": [
    "# Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5f67822d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Make predictions on the test set\n",
    "raw = predictor.predict(X_test.values)\n",
    "\n",
    "#If the output is in bytes, decode it to string\n",
    "if isinstance(raw, bytes):\n",
    "    raw = raw.decode()\n",
    "\n",
    "rows = raw.strip().split('\\n')\n",
    "probs = np.array([list(map(float, r.split(','))) for r in rows])\n",
    "\n",
    "#Get predicted class labels from probabilities\n",
    "pred_class = np.argmax(probs, axis=1)\n",
    "\n",
    "print(classification_report(y_test, pred_class))\n",
    "\n",
    "print(\"Accuracy:\", accuracy_score(y_test, pred_class))"
   ]
  },
